# TermsVault backend configuration

# Port the Express server listens on
PORT=8787

# Comma separated list of allowed CORS origins for local development.
# Leave empty to allow the common Vite and CRA local dev origins by default.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# Mock mode flag. When true, semantic analysis uses the deterministic
# rule based engine instead of a real GenLayer / LLM consensus call.
MOCK_MODE=true

# Safe fetch limits for /api/fetch-document
FETCH_TIMEOUT_MS=8000
FETCH_MAX_BYTES=2000000
